<section class='container mobile-screen'>
  <div class='cadastro-container chalk-auth'>
    <h1>Recuperar Senha</h1>
    <form id='formVerificar' class='tabuada larguraConfirm'>
      <div class='flags-row'>
        <span class='chalk-doodle'>2+2=4</span>
        <span class='chalk-doodle'>7x3</span>
        <span class='chalk-doodle'>9-5</span>
        <span class='chalk-doodle'>6/2</span>
        <span class='chalk-doodle'>x+y</span>
      </div>
      <p>E-mail</p>
      <input
        type='email'
        name='emailCheck'
        id='emailCheck'
        placeholder='Digite seu e-mail'
        value=''
      />
      <div class='cadastrar'>
        <a href='/login' class='btn btn-secondary'>Cancelar</a>
        <button
          type='button'
          id='verifyEmail'
          class='btn btn-primary'
        >Verificar</button>
      </div>
    </form>
  </div>
</section>
