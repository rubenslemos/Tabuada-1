<header>
  <nav id='topo' class='mobile-topbar'>
    <div class='mobile-menu'>
      <div class='line1'></div>
      <div class='line2'></div>
      <div class='line3'></div>
    </div>

    <ul class='nav-list'>
      <li class='menu' id='acompanhamento'>
        <a href='/performance' id='desempenho'>Desempenho</a>
      </li>
      <li class='menu' id='menu-soma'>
        <a href='#' class='soma' value='soma'>Adição
          <i class='fa-solid fa-angles-right'></i></a>
        <ul class='submenu itensSoma soma' id='soma'>
        </ul>
      </li>
      <li class='menu' id='menu-menos'>
        <a href='#' class='menos' value='menos'>Subtração
          <i class='fa-solid fa-angles-right'></i></a>
        <ul class='submenu itensMenos menos' id='menos'>
        </ul>
      </li>
      <li class='menu' id='menu-vezes'>
        <a href='#' class='vezes' value='vezes'>Multiplicação
          <i class='fa-solid fa-angles-right'></i></a>
        <ul class='submenu itensVezes vezes' id='vezes'>
        </ul>
      </li>
      <li class='menu' id='menu-dividir'>
        <a href='#' class='dividir' value='dividir'>Divisão
          <i class='fa-solid fa-angles-right'></i></a>
        <ul class='submenu itensDividir dividir' id='dividir'>
        </ul>
      </li>
      <li class='menu' id='menu-todas'>
        <a href='#' class='todas' value='todas'>Todas
          <i class='fa-solid fa-angles-right'></i></a>
        <ul class='submenu itensTodas todas' id='todas'>
        </ul>
      </li>
      <li class='menu' id='permissao-menu'>
        <a href='/acessos' id='permissao-link'>Permissões</a>
      </li>
      <li class='menu' id='logout-menu'>
        <a href='/logout' id='logout-btn'>Sair</a>
      </li>
    </ul>
    <button
      id='dicasBtn'
      class='menu dicas-btn'
      type='button'
      title='Dicas de Tabuada'
    >
      <i class='fa-solid fa-lightbulb'></i>
    </button>
    <a class='logo' href='/tabuada'>Tabuada</a>
    <span class='user-name'>Olá, {{user.name}}</span>
    <div class='premios-header'>
      <!-- Espaço para elementos de prêmios no header -->
    </div>
  </nav>
</header>

<section class='container mobile-screen'>
  <h1>Qual o valor?</h1>
  <section class='tabuada chalk-board'>
    <div class='flags-row'>
        <span class='chalk-doodle'>2+2=4</span>
        <span class='chalk-doodle'>7x3</span>
        <span class='chalk-doodle'>9-5</span>
        <span class='chalk-doodle'>6/2</span>
        <span class='chalk-doodle'>x+y</span>
      </div>
    <img src='/img/estrela.png' alt='' class='side-sticker left-sticker' />
    <img src='/img/calculadora.png' alt='' class='side-sticker right-sticker' />
    <div class='conta'>
      <div class='chalk-decor'>
        <span class='cd c1'>✦</span>
        <span class='cd c2'>•</span>
        <span class='cd c3'>□</span>
        <span class='cd c4'>•</span>
        <span class='cd c5'>△</span>
        <span class='cd c6'>1+1</span>
        <span class='cd c7'>3x3</span>
      </div>
      <div class='equation-row'>
        <div id='numerador'><p class='numerador'></p></div>
        <div class='op-wrap'><span class='sinal'><i></i></span></div>
        <div id='denominador'><p class='denominador'></p></div>
      </div>
      <label for='resultado' class='answer-label'>Resposta</label>
      <div class='resultado'>
        <input type='number' id='resultado' />
      </div>
    </div>
  </section>
  <section class='btn cards-row'>
    <button class='anterior'>Finalizar</button>
    <button class='resposta'>Verificar</button>
  </section>
  <section class='score-board-web'>
    <div class='score-board-inner'>
      <p class='jogou'>Jogos: 0</p>
      <p class='acertou'>Acertos: 0</p>
      <p class='errou'>Erros: 0</p>
    </div>
  </section>
  <section class='footer-decor-web'>
    <img src='/img/estrela.png' alt='' />
    <img src='/img/check2.png' alt='' />
    <img src='/img/calculadora.png' alt='' />
    <img src='/img/redCross2.png' alt='' />
    <img src='/img/enquete.png' alt='' />
  </section>
</section>

<!-- Modais para resultados -->
<dialog class='dialog'>
  <img class='imagem' /><h2 class='sucess'></h2>
  <small>O que você quer fazer agora?</small>
  <div class='modal'>
    <button class='btn voltar'>Refazer</button>
    <button class='btn proxima'>Próxima</button>
    <button class='btn fechar'>Finalizar</button>
  </div>
</dialog>

<dialog class='fim'>
  <p class='usuario'>Resumo da Rodada</p>
  <div class='fimdiv'>
    <img src='/img/enquete.png' alt='resultado' />
    <div>
      <p class='jogou'></p>
      <p class='acertou'></p>
      <p class='errou'></p>
    </div>
  </div>
  <button class='btn ok'>OK</button>
</dialog>
