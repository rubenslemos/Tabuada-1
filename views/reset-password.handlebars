<section class='container mobile-screen'>
  <div class='cadastro-container chalk-auth'>
    <h1>Alterar Senha</h1>
    <form
      id='formAlterar'
      action='/auth/login/reset_password'
      class='tabuada larguraConfirm'
      method='post'
    >
      <div class='flags-row'>
        <span class='chalk-doodle'>2+2=4</span>
        <span class='chalk-doodle'>7x3</span>
        <span class='chalk-doodle'>9-5</span>
        <span class='chalk-doodle'>6/2</span>
        <span class='chalk-doodle'>x+y</span>
      </div>
      <p>E-mail</p>
      <input
        type='email'
        name='emailAlterar'
        id='emailAlterar'
        placeholder='Digite seu e-mail'
        value=''
        readonly
      />
      <input type='hidden' name='token' id='token' value='' />
      <p>Nova Senha</p><div>
        <input
          type='password'
          name='passwordAlterar'
          id='passwordAlterar'
          placeholder='Digite sua nova senha'
          value=''
        /><i class='fa-regular fa-eye'></i></div>
      <p>Confirmar Nova Senha</p><div>
        <input
          type='password'
          name='ConfirmPasswordAlterar'
          id='ConfirmPasswordAlterar'
          placeholder='Confirme sua nova senha'
          value=''
        /><i class='fa-regular fa-eye'></i></div>
      <div class='cadastrar'>
        <a href='/login' class='btn btn-secondary'>Voltar</a>
        <button
          type='button'
          id='alterarSenha'
          class='btn btn-primary'
        >Alterar</button>
      </div>
    </form>
  </div>
</section>
